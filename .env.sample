# Required: Your Telegram Bot token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Optional: path to the SQLite database file
DATABASE_PATH=birthday_bot.db

# Optional: hour (UTC, 24h) to send the monthly reminder 
# (note: UTC = SGT - 8 so e.g. 12h in SGT is 4h in UTC)
REMINDER_HOUR=4

# Optional: how many days before end-of-month to trigger the reminder
REMINDER_DAYS_BEFORE_END=7
